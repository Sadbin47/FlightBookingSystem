{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/admin/bookings/[id]",
      "regex": "^/admin/bookings/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/admin/bookings/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/customer/bookings/[id]",
      "regex": "^/customer/bookings/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/customer/bookings/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/customer/flights/[id]/book",
